# Copy this file to backend/.env and fill in your key.
# Required for the /chat RAG endpoint (answer generation via Purdue RCAC GenAI Studio).
PURDUE_GENAI_API_KEY=
# Model to use for generation. Must be one the GenAI Studio offers
# (see https://genai.rcac.purdue.edu/api/models). Example default:
PURDUE_GENAI_MODEL=llama3.1:latest
